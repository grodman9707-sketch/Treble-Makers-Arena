# Treble-Makers — environment variables
# Copy to .env and fill in values for local dev or production.
# Never commit .env or lazy-credentials.json (both are gitignored).

# ─── Server ───
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Soft launch: invite-only arena (testers register → admin approves).
# Set to 0 / false for full public open launch later.
SOFT_LAUNCH=1

# Behind Caddy/nginx/Cloudflare. Set to 1 so rate limits and
# auth throttling see the real client IP from X-Forwarded-For.
TRUST_PROXY=1

# ─── Admin seed (first run only, when data.json does not exist) ───
# ADMIN_USERNAME=GViking01
# Use a strong password (8+ chars). If omitted, a random one-time password
# is printed in the server logs and mustChangePassword is set.
# ADMIN_PASSWORD=

# ─── Security ───
# bcrypt cost factor (8–15). Default 10 is fine; raise on faster hardware.
BCRYPT_ROUNDS=10

# Opaque session token lifetime (ms). Default = 30 days.
# SESSION_TTL_MS=2592000000
# MAX_SESSIONS_PER_USER=8

# HTTP API rate limit: max requests per IP per minute (/api/* routes).
API_RATE_MAX=60

# WebSocket: max concurrent sockets per IP.
MAX_WS_PER_IP=25

# WebSocket: max messages per socket per second (flood guard).
MAX_MSGS_PER_SEC=40

# Auth: max register+login attempts per IP per 5-minute window.
AUTH_MAX_ATTEMPTS=15

# ─── Password reset email (Resend) ───
# Required for "Forgot password". Registration still stores email without these.
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Treble-Makers <noreply@yourdomain.com>
# Public site URL used in reset links (no trailing slash):
# APP_URL=https://yourdomain.com
# Optional token lifetime in ms (default 1 hour):
# PASSWORD_RESET_TTL_MS=3600000

# ─── Data backups ───
# Timestamped copies of data.json written to backups/ (also on shutdown).
BACKUP_INTERVAL_MS=21600000
MAX_BACKUPS=10

# Offsite copies (pick one or both):
# Copy each backup into another directory (USB mount, synced folder, etc.)
# BACKUP_OFFSITE_DIR=/var/backups/treble-makers
# Or run a shell command with the backup file path as the first argument:
# BACKUP_OFFSITE_CMD=rclone copy "$1" remote:treble-makers-backups/

# ─── WebRTC TURN (optional — improves webcam behind strict NATs) ───
# Comma-separated TURN URLs, e.g. turn:turn.example.com:3478
# TURN_URLS=
# TURN_USERNAME=
# TURN_CREDENTIAL=

# ─── Error tracking (optional) ───
# npm install @sentry/node   then set:
# SENTRY_DSN=https://....@o....ingest.sentry.io/....

# ─── Lazy Leagues standings proxy (optional) ───
# The /api/lazy-standings endpoint signs into Firebase to read division
# leaders. Without credentials the endpoint returns 502 gracefully.
# LAZY_LEAGUES_EMAIL=
# LAZY_LEAGUES_PASSWORD=
# Or supply a ready-made Firebase ID token (overrides email/password sign-in):
# LAZY_LEAGUES_TOKEN=
